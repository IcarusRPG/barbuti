generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  BARBER
  RECEPTION
}

enum AppointmentStatus {
  PENDENTE
  AGUARDANDO_APROVACAO
  CONFIRMADO
  CANCELADO
  CONCLUIDO
  NAO_COMPARECEU
}

enum AppointmentOrigin {
  PUBLICO
  INTERNO
  WHATSAPP_BOT
  MANUAL
}

enum PaymentMethod {
  PIX
  CARTAO
  DINHEIRO
}

model User {
  id                    String   @id @default(cuid())
  username              String   @unique
  passwordHash          String
  role                  UserRole
  mustChangePassword    Boolean  @default(true)
  active                Boolean  @default(true)
  employee              Employee?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Permission {
  id          String @id @default(cuid())
  role        UserRole
  resource    String
  action      String
}

model Employee {
  id          String   @id @default(cuid())
  fullName    String
  phone       String?
  email       String?
  active      Boolean  @default(true)
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  barber      Barber?
  createdAt   DateTime @default(now())
}

model Barber {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id])
  photoUrl        String?
  specialties     String[]
  approvalMode    Boolean  @default(false)
  active          Boolean  @default(true)
  services        BarberService[]
  weeklyHours     WeeklySchedule[]
  leaves          Leave[]
}

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  active          Boolean  @default(true)
  barbers         BarberService[]
}

model BarberService {
  id        String  @id @default(cuid())
  barberId  String
  serviceId String
  barber    Barber  @relation(fields: [barberId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])
  @@unique([barberId, serviceId])
}

model Client {
  id             String   @id @default(cuid())
  fullName       String
  phone          String?
  whatsapp       String?
  email          String?
  birthDate      DateTime?
  notes          String?
  preferences    String?
  recurring      Boolean  @default(false)
  lastServiceAt  DateTime?
  appointments   Appointment[]
  conversations  Conversation[]
}

model Appointment {
  id                String            @id @default(cuid())
  clientId           String
  barberId           String
  serviceId          String
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus
  origin             AppointmentOrigin
  observation        String?
  client             Client            @relation(fields: [clientId], references: [id])
  barber             Barber            @relation(fields: [barberId], references: [id])
  service            Service           @relation(fields: [serviceId], references: [id])
  statusHistory      AppointmentStatusHistory[]
  payment            Payment?
}

model AppointmentStatusHistory {
  id              String            @id @default(cuid())
  appointmentId   String
  status          AppointmentStatus
  changedBy       String?
  changedAt       DateTime          @default(now())
  appointment     Appointment       @relation(fields: [appointmentId], references: [id])
}

model WeeklySchedule {
  id          String   @id @default(cuid())
  barberId    String
  weekday     Int
  startTime   String
  endTime     String
  intervalMin Int      @default(0)
  barber      Barber   @relation(fields: [barberId], references: [id])
}

model Holiday {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
}

model Leave {
  id          String   @id @default(cuid())
  barberId    String
  startAt     DateTime
  endAt       DateTime
  reason      String?
  barber      Barber   @relation(fields: [barberId], references: [id])
}

model Conversation {
  id          String   @id @default(cuid())
  clientId    String
  externalRef String?
  channel     String
  client      Client   @relation(fields: [clientId], references: [id])
  messages    Message[]
  createdAt   DateTime @default(now())
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderType      String
  body            String
  metadata        Json?
  sentAt          DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
}

model Integration {
  id            String   @id @default(cuid())
  provider      String
  config        Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model BrandSetting {
  id            String   @id @default(cuid())
  companyName   String
  logoUrl       String
  primaryRgb    String
  secondaryRgb  String
  accentRgb     String
  updatedAt     DateTime @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  discount        Decimal       @db.Decimal(10, 2) @default(0)
  method          PaymentMethod
  paid            Boolean       @default(false)
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  commission      Commission?
}

model Commission {
  id          String   @id @default(cuid())
  paymentId   String   @unique
  barberId    String
  amount      Decimal  @db.Decimal(10, 2)
  payment     Payment  @relation(fields: [paymentId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  payload     Json?
  createdAt   DateTime @default(now())
}
